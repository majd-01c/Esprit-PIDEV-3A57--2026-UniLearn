{% extends 'base.html.twig' %}

{% block title %}Availability results{% endblock %}

{% block body %}
<div class="container py-4">
    {% include 'IArooms/timetable/_warning.html.twig' %}

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Availability results</h1>
            {% if upload %}
                <p class="text-muted mb-0">{{ upload.originalFilename }}</p>
            {% endif %}
        </div>
        <a href="{{ path('app_availability_index') }}" class="btn btn-outline-primary">Back to search</a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            {{ form_start(form, { action: path('app_availability_results'), method: 'GET' }) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.upload) }}</div>
                    <div class="col-md-3">{{ form_row(form.date) }}</div>
                    <div class="col-md-3">{{ form_row(form.startTime) }}</div>
                    <div class="col-md-3">{{ form_row(form.endTime) }}</div>
                    <div class="col-md-3">{{ form_row(form.roomFilter) }}</div>
                    <div class="col-md-3">{{ form_row(form.buildingFilter) }}</div>
                </div>
                <div class="mt-3 d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary" type="submit">Search again</button>
                    {% if upload %}
                        <button
                            class="btn btn-outline-danger"
                            type="submit"
                            form="delete-selected-scrape-form"
                            id="delete-selected-scrape-button"
                        >
                            <i class="bi bi-trash me-1"></i> Delete selected
                        </button>
                    {% endif %}
                </div>
            {{ form_end(form) }}

            {% if upload %}
                <form
                    method="post"
                    id="delete-selected-scrape-form"
                    action="{{ path('app_timetable_delete', { id: upload.id }) }}"
                    data-action-template="{{ path('app_timetable_delete', { id: '__ID__' }) }}"
                    data-select-id="{{ form.upload.vars.id }}"
                >
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_timetable') }}">
                </form>
            {% endif %}
        </div>
    </div>

    {% if availability is null %}
        <div class="alert alert-warning">No availability result to show yet. Use the search form above.</div>
    {% else %}
        <div class="row g-3 mb-4">
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Date</div><div class="fw-semibold">{{ availability.date }}</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Time slot</div><div class="fw-semibold">{{ availability.startTime }} - {{ availability.endTime }}</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Empty rooms</div><div class="fw-semibold">{{ availability.emptyRooms|length }}</div></div></div></div>
            <div class="col-md-3"><div class="card border-0 shadow-sm"><div class="card-body"><div class="text-muted small">Occupied rooms</div><div class="fw-semibold">{{ availability.occupiedRooms|length }}</div></div></div></div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h2 class="h5 mb-3 text-success">Empty rooms</h2>
                        <div class="d-flex flex-wrap gap-2">
                            {% for room in availability.emptyRooms %}
                                <span class="badge rounded-pill text-bg-success">{{ room.name }}</span>
                            {% else %}
                                <div class="text-muted">No empty rooms found for this slot.</div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-body">
                        <h2 class="h5 mb-3 text-danger">Occupied rooms</h2>
                        <div class="row g-3">
                            {% for booking in availability.occupiedRooms %}
                                <div class="col-md-6">
                                    <div class="card border-start border-4 border-danger bg-light h-100">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between gap-2">
                                                <div class="fw-semibold">{{ booking.room }}</div>
                                                <span class="badge text-bg-danger">Occupied</span>
                                            </div>
                                            <div class="text-muted small mb-2">{{ booking.group }} · {{ booking.course }}</div>
                                            <div class="small">{{ booking.date }} · {{ booking.startTime }} - {{ booking.endTime }}</div>
                                            <div class="small text-muted">Source page: {{ booking.sourcePage }}</div>
                                        </div>
                                    </div>
                                </div>
                            {% else %}
                                <div class="col-12 text-muted">No occupied rooms for this slot.</div>
                            {% endfor %}
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <h2 class="h5 mb-3">Occupied details</h2>
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Room</th>
                                        <th>Group</th>
                                        <th>Course</th>
                                        <th>Start</th>
                                        <th>End</th>
                                        <th>Source page</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for booking in availability.occupiedRooms %}
                                        <tr>
                                            <td>{{ booking.room }}</td>
                                            <td>{{ booking.group }}</td>
                                            <td>{{ booking.course }}</td>
                                            <td>{{ booking.startTime }}</td>
                                            <td>{{ booking.endTime }}</td>
                                            <td>{{ booking.sourcePage }}</td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="6" class="text-muted">No occupied room details to show.</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if upload %}
        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var deleteForm = document.getElementById('delete-selected-scrape-form');
                var deleteButton = document.getElementById('delete-selected-scrape-button');
                if (!deleteForm || !deleteButton) {
                    return;
                }

                var uploadSelect = document.getElementById(deleteForm.dataset.selectId);
                var actionTemplate = deleteForm.dataset.actionTemplate;
                var syncDeleteAction = function () {
                    var selectedId = uploadSelect ? uploadSelect.value : '';
                    deleteButton.disabled = selectedId === '';
                    if (selectedId !== '') {
                        deleteForm.action = actionTemplate.replace('__ID__', selectedId);
                    }
                };

                syncDeleteAction();
                if (uploadSelect) {
                    uploadSelect.addEventListener('change', syncDeleteAction);
                }

                deleteForm.addEventListener('submit', function (event) {
                    syncDeleteAction();
                    var selectedLabel = uploadSelect && uploadSelect.selectedOptions.length > 0
                        ? uploadSelect.selectedOptions[0].textContent.trim()
                        : 'this Esprit scrape';

                    if (!window.confirm('Delete ' + selectedLabel + ' and all its bookings?')) {
                        event.preventDefault();
                    }
                });
            });
        </script>
    {% endif %}
{% endblock %}
