{% extends 'base.html.twig' %}

{% block title %}Room details{% endblock %}

{% block body %}
<div class="container py-4">
    {% include 'IArooms/timetable/_warning.html.twig' %}

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Room {{ room.name }}</h1>
            <p class="text-muted mb-0">Room details and bookings history.</p>
        </div>
        <a href="{{ path('app_room_index') }}" class="btn btn-outline-primary">Back to rooms</a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Building</div><div class="fw-semibold">{{ room.building ?: 'N/A' }}</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Capacity</div><div class="fw-semibold">{{ room.capacity ?: 'N/A' }}</div></div></div></div>
        <div class="col-md-4"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Type</div><div class="fw-semibold">{{ room.type ?: 'N/A' }}</div></div></div></div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Day</th>
                            <th>Group</th>
                            <th>Course</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Source page</th>
                            <th>Scrape</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for booking in bookings %}
                            <tr>
                                <td>{{ booking.bookingDate ? booking.bookingDate|date('Y-m-d') : 'N/A' }}</td>
                                <td>{{ booking.dayName }}</td>
                                <td>{{ booking.groupName }}</td>
                                <td>{{ booking.courseName }}</td>
                                <td>{{ booking.startTime ? booking.startTime|date('H:i') : 'N/A' }}</td>
                                <td>{{ booking.endTime ? booking.endTime|date('H:i') : 'N/A' }}</td>
                                <td>{{ booking.sourcePage }}</td>
                                <td>{{ booking.timetableUpload ? booking.timetableUpload.originalFilename : (selectedUpload ? selectedUpload.originalFilename : 'All scrapes') }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="8" class="text-muted">No bookings found for this room.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
