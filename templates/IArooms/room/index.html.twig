{% extends 'base.html.twig' %}

{% block title %}Rooms{% endblock %}

{% block body %}
<div class="container py-4">
    {% include 'IArooms/timetable/_warning.html.twig' %}

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Detected rooms</h1>
            <p class="text-muted mb-0">Search rooms detected in the latest Esprit scrape.</p>
        </div>
        <a href="{{ path('app_timetable_scrape') }}" class="btn btn-primary">Scrape Esprit timetable</a>
    </div>

    <form method="get" class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label for="q" class="form-label">Search room</label>
                    <input type="text" name="q" id="q" value="{{ query }}" class="form-control" placeholder="A42, H201, M204">
                </div>
                <div class="col-md-4">
                    <button class="btn btn-outline-primary w-100" type="submit">Search</button>
                </div>
            </div>
        </div>
    </form>

    <div class="row g-3">
        {% for room in rooms %}
            <div class="col-md-6 col-xl-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h2 class="h5 mb-0">{{ room.name }}</h2>
                            <span class="badge text-bg-light">{{ room.roomBookings|length }} bookings</span>
                        </div>
                        <div class="text-muted small mb-3">
                            <div>Building: {{ room.building ?: 'N/A' }}</div>
                            <div>Capacity: {{ room.capacity ?: 'N/A' }}</div>
                            <div>Type: {{ room.type ?: 'N/A' }}</div>
                        </div>
                        <div class="mt-auto">
                            <a href="{{ path('app_room_show', { id: room.id, upload: latestUpload ? latestUpload.id : null }) }}" class="btn btn-sm btn-outline-primary">View details</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="alert alert-info">No Esprit rooms found yet. Run a scrape first.</div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
