{% extends 'base.html.twig' %}

{% block title %}Scrape Esprit timetable{% endblock %}

{% block body %}
<div class="container py-4">
    {% include 'IArooms/timetable/_warning.html.twig' %}

    <div class="row justify-content-center">
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <div class="mb-4">
                        <span class="badge text-bg-info-subtle text-info border border-info-subtle mb-2">Esprit live portal</span>
                        <h1 class="h3 mb-2">Scrape Esprit rooms</h1>
                        <p class="text-muted mb-0">Fetch the latest timetable from Emplois.aspx and store only rooms detected from Esprit.</p>
                    </div>

                    {{ form_start(form) }}
                        <div class="row g-3">
                            <div class="col-md-6">{{ form_row(form.studentId) }}</div>
                            <div class="col-md-6">{{ form_row(form.password) }}</div>
                            <div class="col-md-6">{{ form_row(form.timeoutSeconds) }}</div>
                        </div>
                        <div class="mt-4 d-flex gap-2 flex-wrap">
                            <button type="submit" class="btn btn-primary">Scrape timetable</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
