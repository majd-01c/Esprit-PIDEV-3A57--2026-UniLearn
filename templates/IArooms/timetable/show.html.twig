{% extends 'base.html.twig' %}

{% block title %}Esprit timetable details{% endblock %}

{% block body %}
<div class="container py-4">
    {% include 'IArooms/timetable/_warning.html.twig' %}

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4">
        <div>
            <h1 class="h3 mb-1">Esprit timetable details</h1>
            <p class="text-muted mb-0">{{ upload.originalFilename }}</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ path('app_timetable_scrape') }}" class="btn btn-outline-primary">Scrape latest Esprit timetable</a>
            <a href="{{ path('app_availability_index', { upload: upload.id }) }}" class="btn btn-primary">Check availability</a>
            <form
                method="post"
                action="{{ path('app_timetable_delete', { id: upload.id }) }}"
                onsubmit="return confirm('Delete this Esprit scrape and all its bookings?');"
            >
                <input type="hidden" name="_token" value="{{ csrf_token('delete_timetable') }}">
                <button class="btn btn-outline-danger" type="submit">
                    <i class="bi bi-trash me-1"></i> Delete
                </button>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Week start</div><div class="fs-5 fw-semibold">{{ upload.weekStart ? upload.weekStart|date('d/m/Y') : 'Unknown' }}</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Week end</div><div class="fs-5 fw-semibold">{{ upload.weekEnd ? upload.weekEnd|date('d/m/Y') : 'Unknown' }}</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Total rooms</div><div class="fs-5 fw-semibold">{{ upload.totalRooms }}</div></div></div></div>
        <div class="col-md-3"><div class="card shadow-sm border-0"><div class="card-body"><div class="text-muted small">Bookings</div><div class="fs-5 fw-semibold">{{ upload.totalBookings }}</div></div></div></div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3"><div class="text-muted small">Pages</div><div class="fw-semibold">{{ upload.totalPages }}</div></div>
                <div class="col-md-3"><div class="text-muted small">Ignored online sessions</div><div class="fw-semibold">{{ upload.ignoredOnlineSessions }}</div></div>
                <div class="col-md-3"><div class="text-muted small">Scraped at</div><div class="fw-semibold">{{ upload.uploadedAt ? upload.uploadedAt|date('d/m/Y H:i') : 'Unknown' }}</div></div>
                <div class="col-md-3"><div class="text-muted small">Room source</div><div class="fw-semibold">Esprit detected rooms</div></div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-secondary" href="{{ path('app_room_index') }}">Rooms</a>
            <a class="btn btn-outline-secondary" href="{{ path('app_conflict_index', { upload: upload.id }) }}">Conflicts</a>
            {% if latestUpload and latestUpload.id != upload.id %}
                <span class="badge text-bg-light align-self-center">Latest scrape differs from this record</span>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
