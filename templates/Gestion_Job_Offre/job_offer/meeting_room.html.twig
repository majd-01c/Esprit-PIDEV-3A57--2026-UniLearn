<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ meeting.title }} - UniLearn Interview</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html,
        body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }

        .meeting-header {
            height: 58px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            padding: 10px 18px;
            background: #123047;
            color: #fff;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.24);
        }

        .meeting-header-left,
        .meeting-header-right {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .back-link,
        .end-button {
            border: 0;
            border-radius: 7px;
            color: #fff;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 14px;
            line-height: 1;
            padding: 9px 13px;
            text-decoration: none;
            white-space: nowrap;
        }

        .back-link {
            background: rgba(255, 255, 255, 0.14);
        }

        .back-link:hover {
            background: rgba(255, 255, 255, 0.22);
            color: #fff;
        }

        .end-button {
            background: #dc3545;
            cursor: pointer;
        }

        .end-button:hover {
            background: #bd2d3b;
        }

        .meeting-title {
            min-width: 0;
        }

        .meeting-title strong,
        .meeting-title small {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .meeting-title small {
            color: rgba(255, 255, 255, 0.78);
            margin-top: 2px;
        }

        .live-pill {
            align-items: center;
            background: rgba(255, 255, 255, 0.16);
            border-radius: 999px;
            display: inline-flex;
            font-size: 12px;
            gap: 7px;
            padding: 6px 10px;
            white-space: nowrap;
        }

        .live-dot {
            animation: pulse 1.5s infinite;
            background: #36d399;
            border-radius: 50%;
            height: 9px;
            width: 9px;
        }

        #meet {
            background: #202124;
            height: calc(100vh - 58px);
            width: 100%;
        }

        .loading,
        .error-message {
            align-items: center;
            color: #fff;
            display: flex;
            flex-direction: column;
            height: 100%;
            justify-content: center;
            text-align: center;
        }

        .spinner {
            animation: spin 1s linear infinite;
            border: 4px solid rgba(255, 255, 255, 0.16);
            border-radius: 50%;
            border-top-color: #36d399;
            height: 48px;
            margin-bottom: 18px;
            width: 48px;
        }

        .error-message {
            align-items: flex-start;
            background: #2d2d2d;
            border-radius: 8px;
            height: auto;
            margin: 40px auto;
            max-width: 640px;
            padding: 32px;
            text-align: left;
        }

        .error-message h3 {
            color: #ff8a8a;
            margin-bottom: 12px;
        }

        .error-message ul {
            margin-top: 14px;
            padding-left: 20px;
        }

        .error-message li {
            margin: 8px 0;
        }

        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.72; transform: scale(1.18); }
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @media (max-width: 760px) {
            .meeting-header {
                height: auto;
                align-items: flex-start;
                flex-direction: column;
            }

            .meeting-header-left,
            .meeting-header-right {
                width: 100%;
            }

            .meeting-header-right {
                justify-content: space-between;
            }

            #meet {
                height: calc(100vh - 108px);
            }
        }
    </style>
</head>
<body>
    <div class="meeting-header">
        <div class="meeting-header-left">
            {% if isPartner %}
                <a href="{{ path('app_partner_job_offer_applications', {id: application.offer.id}) }}" class="back-link">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            {% else %}
                <a href="{{ path('app_student_job_applications') }}" class="back-link">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            {% endif %}

            <div class="meeting-title">
                <strong>{{ meeting.title }}</strong>
                <small>{{ application.offer.title }}{% if application.student %} - {{ application.student.name ?: application.student.email }}{% endif %}</small>
            </div>

            <span class="live-pill"><span class="live-dot"></span> LIVE</span>
        </div>

        <div class="meeting-header-right">
            <span style="font-size: 12px; opacity: 0.82;">
                <i class="bi bi-person-fill"></i> {{ username }}
            </span>

            {% if isPartner %}
                <form method="post" action="{{ path('app_partner_job_offer_meeting_end', {id: meeting.id}) }}" onsubmit="return confirm('End this interview meeting?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('end_job_offer_meeting' ~ meeting.id) }}">
                    <button type="submit" class="end-button">
                        <i class="bi bi-stop-circle"></i> End Meeting
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    <div id="meet">
        <div class="loading">
            <div class="spinner"></div>
            <p>Connecting to interview meeting...</p>
        </div>
    </div>

    <script>
        const script = document.createElement('script');
        script.src = "https://{{ jitsi_host|e('js') }}/external_api.js";
        script.async = true;

        script.onerror = function() {
            document.getElementById('meet').innerHTML = `
                <div class="error-message">
                    <h3>Cannot connect to the video server</h3>
                    <p>Unable to load the interview meeting interface.</p>
                    <ul>
                        <li>Jitsi host: <strong>{{ jitsi_host }}</strong></li>
                        <li>Open <a href="https://{{ jitsi_host }}" target="_blank" style="color:#7ab8ff;">https://{{ jitsi_host }}</a> to check the server.</li>
                    </ul>
                </div>
            `;
        };

        script.onload = function() {
            setTimeout(function() {
                try {
                    if (typeof JitsiMeetExternalAPI === 'undefined') {
                        throw new Error('JitsiMeetExternalAPI is not defined');
                    }

                    const api = new JitsiMeetExternalAPI("{{ jitsi_host|e('js') }}", {
                        roomName: "{{ meeting.roomCode|e('js') }}",
                        width: "100%",
                        height: "100%",
                        parentNode: document.querySelector('#meet'),
                        configOverwrite: {
                            enableWelcomePage: false,
                            prejoinPageEnabled: false,
                            startWithAudioMuted: false,
                            startWithVideoMuted: false
                        },
                        interfaceConfigOverwrite: {
                            SHOW_JITSI_WATERMARK: false,
                            SHOW_WATERMARK_FOR_GUESTS: false,
                            DEFAULT_BACKGROUND: '#202124'
                        },
                        userInfo: {
                            displayName: "{{ username|e('js') }}"
                        }
                    });

                    api.addListener('readyToClose', function() {
                        window.location.href = "{{ isPartner ? path('app_partner_job_offer_applications', {id: application.offer.id}) : path('app_student_job_applications') }}";
                    });
                } catch (error) {
                    document.getElementById('meet').innerHTML = `
                        <div class="error-message">
                            <h3>Error starting meeting</h3>
                            <p><strong>Error:</strong> ${error.message}</p>
                            <ul>
                                <li>Jitsi host: <strong>{{ jitsi_host }}</strong></li>
                                <li>Try refreshing the page.</li>
                            </ul>
                        </div>
                    `;
                }
            }, 500);
        };

        document.head.appendChild(script);
    </script>
</body>
</html>
